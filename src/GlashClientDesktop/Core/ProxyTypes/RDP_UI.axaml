<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="GlashClientDesktop.Core.ProxyTypes.RDP_UI"
             xmlns:vm="using:GlashClientDesktop.Core.ProxyTypes"
             x:DataType="vm:RDP">
  <Design.DataContext>
    <vm:RDP />
  </Design.DataContext>
  <u:Form LabelPosition="Top" LabelWidth="*" MinWidth="400" HorizontalAlignment="Stretch">
    <TextBox u:FormItem.Label="{Binding Text_User}" Text="{Binding User}" u:FormItem.IsRequired="True" />
    <TextBox u:FormItem.Label="{Binding Text_Password}" Text="{Binding Password}" u:FormItem.IsRequired="True" />
</u:Form>
</UserControl>
